# matrix-voip-agent configuration template
# Copy to .env and fill in the placeholders. Never commit your real .env.
# All 192.168.x.x addresses below are EXAMPLES — substitute your own hosts.

# ============================================================
# Matrix homeserver connection (call signaling + E2EE)
# ============================================================
MATRIX_HOMESERVER_URL=http://127.0.0.1:8008
MATRIX_USER_ID=@your-bot:your-homeserver.example.com
MATRIX_ACCESS_TOKEN=<MATRIX_ACCESS_TOKEN>
MATRIX_DEVICE_ID=OPENCLAW_VOICE
MATRIX_DEVICE_NAME=OpenClaw Voice

# E2EE (encrypted rooms). Recovery key file must live under secrets/ (gitignored).
MATRIX_E2EE_ENABLED=true
MATRIX_E2EE_REQUIRED=false
MATRIX_RECOVERY_KEY_FILE=./secrets/recovery-key.txt
# MATRIX_CRYPTO_STORE_PASSWORD=
MATRIX_AUTO_CROSS_SIGN=true
MATRIX_RESTORE_KEY_BACKUP_ON_START=true
CRYPTO_STORE_PATH=./crypto-store

# Optional secondary bridge account
# BRIDGE_USER_ID=
# BRIDGE_ACCESS_TOKEN=

# Authorization: comma-separated Matrix user IDs allowed to call
AUTHORIZED_USERS=@your-user:your-homeserver.example.com

# ============================================================
# PipeWire virtual device targets (created by setup.sh)
# Use unique names per persona when running multiple agents.
# ============================================================
PIPEWIRE_STT_SINK=input.openclaw_stt_speaker
PIPEWIRE_TTS_SOURCE=openclaw_tts_mic
PIPEWIRE_STT_CAPTURE=openclaw_stt_capture
PIPEWIRE_TTS_SINK=input.openclaw_tts

# ============================================================
# STT — pick ONE primary backend
# ============================================================
# Option 1: local whisper.cpp (built by setup.sh)
WHISPER_ENABLED=true
WHISPER_LANGUAGE=auto
# WHISPER_SERVER_URL=http://127.0.0.1:8178
# WHISPER_SERVER_PORT=8178
# WHISPER_SERVER_BIN=~/whisper.cpp/build/bin/whisper-server
# WHISPER_MODEL_PATH=~/whisper.cpp/models/ggml-small.bin
# WHISPER_VAD_MODEL_PATH=~/whisper.cpp/models/silero-vad.onnx
# WHISPER_AUTO_START=true

# Option 2: OpenAI-compatible ASR server, e.g. github.com/AEON-7/qwen3-asr-server
# OMNI_ASR_ENABLED=true
# OMNI_ASR_BASE_URL=http://192.168.1.116:8500/v1
# OMNI_ASR_MODEL=qwen3-asr-0.6b
# OMNI_ASR_API_KEY=

# Option 3: Mac MLX realtime ASR sidecar
# MAC_ASR_URL=
# MAC_ASR_API_KEY=
# MAC_ASR_MODEL=

# Fallback: OpenAI cloud STT (used if whisper fails)
# OPENAI_API_KEY=<OPENAI_API_KEY>
# OPENAI_STT_MODEL=gpt-4o-transcribe

# ============================================================
# LLM — OpenAI-compatible chat completions
# Must be a VISION-capable model if you enable the video add-on.
# ============================================================
VLLM_BASE_URL=http://192.168.1.116:8000/v1
VLLM_API_KEY=
VLLM_MODEL=your-model-name
# VLLM_SYSTEM_PROMPT=          # blank = built-in voice prompt
# VLLM_TEMPERATURE=0
# VLLM_VOICE_FAST_MODEL=       # defaults to VLLM_MODEL
# VLLM_VOICE_DEEP_MODEL=       # defaults to fast model
# VLLM_VOICE_CHAT_MAX_TOKENS=1024
# VLLM_VOICE_THINKING_MAX_TOKENS=8192
# VLLM_VOICE_THINKING_MODE=auto   # on|off|auto
# VLLM_VOICE_TOOLS_THINKING=on
# VOICE_HISTORY_MAX_MESSAGES=24
# VOICE_HISTORY_KEEP_MESSAGES=12

# ============================================================
# TTS — pick ONE backend
# ============================================================
# Option 1: OpenAI-compatible TTS server, e.g. github.com/AEON-7/qwen3-tts-server
# (VOXTRAL_ prefix is historical — works with any /v1/audio/speech endpoint)
# VOXTRAL_ENABLED=true
# VOXTRAL_BASE_URL=http://192.168.1.116:8002/v1
# VOXTRAL_VOICE=cheerful_female
# VOXTRAL_MODEL=your-tts-model-name
# VOXTRAL_VOICE_DESCRIPTION=
# VOXTRAL_VOICE_STYLE_FIELD=instructions
# VOXTRAL_VOICE_STYLE_TEMPLATE=
# VOXTRAL_LANGUAGE=English
# VOXTRAL_API_KEY=
# Realtime streaming: request stream:true + response_format:pcm and pipe raw
# PCM (s16le mono 24 kHz) into playback as chunks arrive — playback starts at
# the first chunk (~0.4 s on Spark) instead of after full synthesis.
# Recommended true with qwen3-tts-server (faster-qwen3-tts backend).
# VOXTRAL_STREAMING=true
# VOXTRAL_TTS_TIMEOUT_MS=120000
# Voice cloning (Qwen3-TTS-12Hz-1.7B-Base via qwen3-tts-server clone mode):
# VOXTRAL_TTS_MODE=voice_clone
# VOXTRAL_VOICE_CLONE_REF_AUDIO=        # path/URL to reference sample
# VOXTRAL_VOICE_CLONE_REF_TEXT=         # transcript of the reference sample

# Option 2: ElevenLabs cloud TTS
# ELEVENLABS_API_KEY=<ELEVENLABS_API_KEY>
# ELEVENLABS_VOICE_ID=<ELEVENLABS_VOICE_ID>
# ELEVENLABS_MODEL=eleven_flash_v2_5

# Experimental: speech-to-speech (Omni) pipeline
# OMNI_ENABLED=false
# OMNI_BASE_URL=http://192.168.1.116:9000/v1
# OMNI_MODEL=/model
# OMNI_SPEAKER=chelsie
# OMNI_API_KEY=

# ============================================================
# Video add-on (optional — see README Video Calling QuickStart)
# Requires ffmpeg on PATH and a vision-capable VLLM_MODEL.
# ============================================================
VIDEO_ENABLED=false
# VIDEO_FRAME_FPS=1            # frames/sec kept; excess dropped before decode
# VIDEO_FRAME_WIDTH=512        # JPEG width, height keeps aspect
# VIDEO_RING_SIZE=8            # frames kept in the in-memory ring (never on disk)
# VIDEO_AUTO_ATTACH=off        # off|latest — "latest" attaches freshest frame each turn
# VIDEO_LOOK_IMAGE_ROLE=tool   # tool|user — "user" if the chat template rejects images in tool messages

# ============================================================
# Persona, memory, and output
# ============================================================
# VOICE_CALLER_NAME=caller     # what the LLM calls the person on the line
# VOICE_MEMORY_ENABLED=true
# VOICE_MEMORY_PATHS=          # comma-separated markdown files injected into the system prompt
# VOICE_MEMORY_MAX_CHARS=12000
# VOICE_MEMORY_MAX_FILE_CHARS=2400
# VOICE_TTS_RESPONSE_MODE=chunked   # chunked|full

# ============================================================
# Voice tools
# ============================================================
# BRAVE_SEARCH_API_KEY=<BRAVE_SEARCH_API_KEY>   # enables the web_search tool

# ============================================================
# Call limits and outbound-call HTTP API
# ============================================================
MAX_CONCURRENT_CALLS=1
CALL_TIMEOUT_MS=1800000
API_PORT=8179
API_TOKEN=<API_TOKEN>

# Logging (debug, info, warn, error)
LOG_LEVEL=info
